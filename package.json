{
  "name": "openclaw-plugin-cleanshot",
  "version": "1.0.1",
  "description": "OpenClaw tool plugin for controlling CleanShot X on macOS via its official URL Scheme API.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.5.12"
    },
    "build": {
      "openclawVersion": "2026.5.12"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "openclaw.plugin.json",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "tool",
    "cleanshot",
    "screenshot",
    "macos",
    "url-scheme"
  ],
  "license": "MIT",
  "author": "Lyzmin41",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LYzmin41/openclaw-plugin-cleanshot.git"
  },
  "bugs": {
    "url": "https://github.com/LYzmin41/openclaw-plugin-cleanshot/issues"
  },
  "homepage": "https://github.com/LYzmin41/openclaw-plugin-cleanshot#readme",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "clawhub": "^0.18.0",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  }
}
