{
  "name": "openclaw-plugin-cleanshot",
  "version": "0.9.0",
  "description": "OpenClaw tool plugin for controlling CleanShot X on macOS via its official URL Scheme API.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "openclaw.plugin.json",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "tsx --test tests/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "tool",
    "cleanshot",
    "screenshot",
    "macos",
    "url-scheme"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5"
  }
}
