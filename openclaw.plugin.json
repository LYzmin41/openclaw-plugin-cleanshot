{
  "id": "cleanshot",
  "name": "CleanShot",
  "version": "1.0.1",
  "description": "Control CleanShot X on macOS via its official URL Scheme API.",
  "activation": {
    "onStartup": false
  },
  "contracts": {
    "tools": [
      "cleanshot_capture",
      "cleanshot_all_in_one",
      "cleanshot_scrolling_capture",
      "cleanshot_ocr",
      "cleanshot_record_screen",
      "cleanshot_annotate_file",
      "cleanshot_pin_file",
      "cleanshot_quick_access",
      "cleanshot_settings"
    ]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "defaultAction": {
        "type": "string",
        "enum": [
          "copy",
          "save",
          "annotate",
          "upload",
          "pin"
        ],
        "default": "save",
        "description": "Default capture action when a tool call does not provide one."
      },
      "includeGeneratedUrlInResult": {
        "type": "boolean",
        "default": true,
        "description": "Include the generated cleanshot:// URL in tool results."
      }
    }
  }
}
